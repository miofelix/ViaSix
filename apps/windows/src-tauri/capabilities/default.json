{
  "$schema": "https://schema.tauri.app/config/2",
  "identifier": "default",
  "description": "Default ViaSix Windows capabilities",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:allow-show",
    "core:window:allow-hide",
    "core:window:allow-set-focus",
    "core:window:allow-unminimize",
    "shell:allow-open",
    "dialog:default"
  ]
}
